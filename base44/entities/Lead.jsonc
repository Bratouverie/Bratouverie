      "description": "\u0412\u043e\u0437\u0440\u0430\u0441\u0442"
    },
    "preferred_specialty": {
      "type": "string",
      "enum": [
        "operator_bpla",
        "artillerist",
        "svyazist",
        "medic",
        "mechanic",
        "driver",
        "razvedchik",
        "saper",
